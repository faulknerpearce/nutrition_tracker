SUPABASE_URL=https://<your-project>.supabase.co

# Anon key — used by MCP with a user JWT (not the service-role key)
SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard>

# OAuth signing secret for MCP connector auth (Grok, etc.). Generate with:
#   openssl rand -base64 32
OAUTH_SIGNING_SECRET=<random-secret>

# Optional: public origin when running behind a proxy (defaults to request host)
# MCP_PUBLIC_URL=https://nutrition-tracker.pages.dev

# For local stdio MCP: copy access_token from browser session after sign-in
# (DevTools → Application → Local Storage → supabase auth token, or use getSession())
SUPABASE_ACCESS_TOKEN=

# Web app build-time vars (also loaded by Vite from this file in dev)
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard>